{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPMQY3+Yj88DFzjBhZWVwzB"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"_pOXuEFYFCY9","executionInfo":{"status":"ok","timestamp":1778958274574,"user_tz":180,"elapsed":13758,"user":{"displayName":"Rodney N. Silva","userId":"12217589085405269403"}},"outputId":"9d839239-6fd7-4216-d296-f83aa7e62410"},"outputs":[{"output_type":"stream","name":"stdout","text":["Step 0, Loss: 6.834\n","Step 50, Loss: 0.371\n","Step 100, Loss: 0.111\n","Step 150, Loss: 0.059\n","Step 200, Loss: 0.038\n","Step 250, Loss: 0.027\n","Step 300, Loss: 0.020\n","Step 350, Loss: 0.016\n","Step 400, Loss: 0.013\n","Step 450, Loss: 0.010\n","Pred: 308, Real: 308\n"]}],"source":["#A lógica: cada cabeça de atenção ganha sua própria matriz 8x8. Na hora do forward, cada cabeça atualiza e lê a própria memória.\n","import torch\n","import torch.nn as nn\n","import torch.nn.functional as F\n","\n","class HeadMemory(nn.Module):\n","    def __init__(self, dim=8, lr=5e-3):\n","        super().__init__()\n","        self.dim = dim\n","        self.lr = lr\n","\n","        self.register_buffer(\"memory\", torch.zeros(dim, dim))\n","        self.key = nn.Parameter(torch.randn(dim) * 0.02)\n","        self.value = nn.Parameter(torch.randn(dim) * 0.02)\n","        self.W_q = nn.Parameter(torch.randn(dim) * 0.02)\n","        self.W_o = nn.Parameter(torch.randn(dim) * 0.02)\n","\n","    def update(self, h):\n","        h = h.detach()\n","        pred = self.memory @ self.key\n","        err = self.value - pred\n","        with torch.no_grad():\n","            self.memory += self.lr * torch.outer(err, self.key)\n","\n","    def read(self, h):\n","        out = h @ self.memory\n","        return out * self.W_q, out * self.W_o\n","\n","    def reset(self):\n","        self.memory.zero_()\n","\n","class MultiHeadMemory(nn.Module):\n","    def __init__(self, n_heads, mem_dim=8, lr=5e-3):\n","        super().__init__()\n","        # Initialize HeadMemory with mem_dim divided by n_heads\n","        self.heads = nn.ModuleList([HeadMemory(mem_dim // n_heads, lr) for _ in range(n_heads)])\n","        self.n_heads = n_heads\n","\n","    def update_all(self, h_split_list): # h_split_list is list of [B, dim_head]\n","        B = h_split_list[0].shape[0]\n","        for b_idx in range(B):\n","            for head_idx in range(self.n_heads):\n","                h_for_head = h_split_list[head_idx][b_idx] # This is (dim_head,)\n","                self.heads[head_idx].update(h_for_head)\n","\n","    def read_all(self, h_split_list): # h_split_list is list of [B, dim_head]\n","        B = h_split_list[0].shape[0]\n","        all_corr_q, all_corr_o = [], []\n","        for b_idx in range(B):\n","            corr_q_for_batch, corr_o_for_batch = [], []\n","            for head_idx in range(self.n_heads):\n","                h_for_head = h_split_list[head_idx][b_idx] # This is (dim_head,)\n","                q, o = self.heads[head_idx].read(h_for_head) # q, o are (dim_head,)\n","                corr_q_for_batch.append(q)\n","                corr_o_for_batch.append(o)\n","            # Stack results for current batch across heads: [n_heads, dim_head]\n","            all_corr_q.append(torch.stack(corr_q_for_batch, dim=0))\n","            all_corr_o.append(torch.stack(corr_o_for_batch, dim=0))\n","        # Stack results across batches: [B, n_heads, dim_head]\n","        return torch.stack(all_corr_q, dim=0), torch.stack(all_corr_o, dim=0)\n","\n","    def reset(self):\n","        for h in self.heads:\n","            h.reset()\n","\n","class TransformerLayerWithMemory(nn.Module):\n","    def __init__(self, hidden_dim=256, n_heads=4, mem_dim=32): # Increased mem_dim\n","        super().__init__()\n","        assert hidden_dim % n_heads == 0\n","        self.hidden_dim = hidden_dim\n","        self.n_heads = n_heads\n","        self.head_dim = hidden_dim // n_heads\n","\n","        self.attn = nn.MultiheadAttention(hidden_dim, n_heads, batch_first=True)\n","        self.mlp = nn.Sequential(\n","            nn.Linear(hidden_dim, hidden_dim*4),\n","            nn.GELU(),\n","            nn.Linear(hidden_dim*4, hidden_dim)\n","        )\n","        self.norm1 = nn.LayerNorm(hidden_dim)\n","        self.norm2 = nn.LayerNorm(hidden_dim)\n","\n","        # Memória por cabeça\n","        self.memory = MultiHeadMemory(n_heads, mem_dim)\n","\n","        # Projeções pra memória\n","        self.down_proj = nn.Linear(hidden_dim, mem_dim)\n","        self.up_proj = nn.Linear(mem_dim, hidden_dim)\n","\n","    def forward(self, x, update_memory=True):\n","        B, S, D = x.shape\n","\n","        # 1. Projeta pra espaço da memória\n","        h = self.down_proj(x) # [B, S, mem_dim]\n","\n","        # 2. Divide em cabeças pra atualizar cada memória separada\n","        h_split = h.chunk(self.n_heads, dim=-1) # lista de [B, S, mem_dim/n_heads]\n","        h_split = [hs for hs in h_split] # garante que é lista\n","\n","        if update_memory:\n","            for t in range(S):\n","                h_t = torch.cat([hs[:, t] for hs in h_split], dim=-1) # junta de novo por token\n","                h_t_split = h_t.chunk(self.n_heads, dim=-1) # list of [B, dim_head]\n","                self.memory.update_all(h_t_split)\n","\n","        # 3. Lê memória usando último token\n","        h_last_split = [hs[:, -1] for hs in h_split] # list of [B, dim_head]\n","        corr_q, corr_o = self.memory.read_all(h_last_split) # [B, n_heads, mem_dim/n_heads]\n","        corr_o_flat = corr_o.flatten(1) # [B, mem_dim]\n","        corr_o_full = self.up_proj(corr_o_flat) # [B, hidden_dim]\n","\n","        # 4. Atenção normal + correção\n","        attn_out, _ = self.attn(x, x, x)\n","        # Increased gating factor for memory's influence to 1.0\n","        attn_out[:, -1] += corr_o_full * 1.0 # 1.0 é gating pra não bagunçar tudo\n","\n","        x = self.norm1(x + attn_out)\n","        x = self.norm2(x + self.mlp(x))\n","        return x\n","\n","    def reset_memory(self):\n","        self.memory.reset()\n","\n","class MiniLMWithMemory(nn.Module):\n","    def __init__(self, vocab_size, hidden_dim=256, n_layers=2, n_heads=4, mem_dim=32): # Increased mem_dim\n","        super().__init__()\n","        self.embed = nn.Embedding(vocab_size, hidden_dim)\n","        self.pos_embed = nn.Parameter(torch.randn(512, hidden_dim) * 0.02)\n","\n","        self.layers = nn.ModuleList([\n","            TransformerLayerWithMemory(hidden_dim, n_heads, mem_dim)\n","            for _ in range(n_layers)\n","        ])\n","\n","        self.lm_head = nn.Linear(hidden_dim, vocab_size)\n","\n","    def forward(self, x, update_memory=True):\n","        B, S = x.shape\n","        x = self.embed(x) + self.pos_embed[:S]\n","\n","        for layer in self.layers:\n","            x = layer(x, update_memory=update_memory)\n","\n","        logits = self.lm_head(x)\n","        return logits\n","\n","    def reset_memory(self):\n","        for layer in self.layers:\n","            layer.reset_memory()\n","#Teste rápido no Colab\n","#Treino de brinquedo pra ver se aprende\n","device = 'cuda' if torch.cuda.is_available() else 'cpu'\n","model = MiniLMWithMemory(vocab_size=1000, hidden_dim=128, n_layers=2, n_heads=4, mem_dim=32).to(device) # Increased mem_dim\n","opt = torch.optim.AdamW(model.parameters(), lr=3e-4)\n","\n","#Simula sequência: treina pra memorizar uma frase\n","model.reset_memory()\n","seq = torch.randint(0, 500, (1, 20)).to(device) # Increased vocab_size range for sequence tokens\n","\n","for step in range(500): # Increased training steps to 500\n","    opt.zero_grad()\n","    logits = model(seq, update_memory=True)\n","    loss = F.cross_entropy(logits[:, :-1].reshape(-1, 1000), seq[:, 1:].reshape(-1))\n","    loss.backward()\n","    opt.step()\n","\n","    if step % 50 == 0: # Adjusted print frequency\n","        print(f\"Step {step}, Loss: {loss.item():.3f}\")\n","\n","#Testa leitura: desliga update e vê se lembra\n","model.reset_memory() # limpa\n","with torch.no_grad():\n","    # Feed prefix and update memory. The output logits will contain predictions for all positions in the prefix.\n","    logits_prefix = model(seq[:, :-5], update_memory=True) # (B, S_prefix, vocab_size)\n","\n","    # The prediction for the token immediately after the prefix (seq[0, -5])\n","    # is given by the logits at the last position of logits_prefix.\n","    pred_next_token = logits_prefix[:, -1, :].argmax(-1) # (B,)\n","\n","    # The actual next token in the sequence is seq[0, -5]\n","    real_next_token = seq[:, -5] # (B,)\n","\n","    print(f\"Pred: {pred_next_token.item()}, Real: {real_next_token.item()}\")\n","\n","\n","#Como isso mapeia pro paper:\n","\n","#1. *Memória por cabeça*: `MultiHeadMemory` cria uma `HeadMemory` pra cada cabeça. No paper usam 8x8 por cabeça.\n","#2. *Atualização online*: `update_all` roda 1 passo de SGD por token durante o forward. Não usa backward.\n","#3. *Leitura*: `read_all` pega o estado atual e retorna correção que é somada no output da atenção.\n","#4. *Reset*: chama `reset_memory()` entre contextos diferentes pra não misturar memória.\n","\n","#*Dicas pra fazer funcionar melhor:*\n","\n","#- Começa com `mem_dim=8` e `lr=5e-3`. Se a loss oscilar muito, abaixa o lr.\n","#- O fator 0.1 no `corr_o_full * 0.1` é um gating manual. Sem isso a correção domina e quebra o modelo.\n","#- Treina `key`, `value`, `W_q`, `W_o` no dataset alvo por 1-2 epochs antes de usar. Eles são os únicos parâmetros que aprendem via gradiente normal."]}]}